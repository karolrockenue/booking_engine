# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# source design assets (not deployed)
/design/

# scratch / smoke test output (may contain Cloudbeds response data)
/tmp/

# Claude Code local state (per-developer, not project)
/.claude/

# Portico — local design references (huge image bundles, do not ship)
/design/
/design_handoff_*/

# Loose root images (originals; resized versions live in public/portico/)
/Portico Logo.JPG
/portico-logo.png
/portico-logo-white.png
/PorticoHotel_*.jpg
/Screenshot*.png
